---
import { Image } from 'astro:assets';
import { ImageLightbox } from '@/components/ui/lightbox';

const stockImages = await Astro.glob('../../assets/products/stock/*.{jpg,jpeg,png}').then(
  (files) => {
    return files.map((file) => file.default);
  }
);

const thumbnailImages = await Astro.glob(
  '../../assets/products/stock/thumbnails/*.{jpg,jpeg,png}'
).then((files) => {
  return files.map((file) => file.default);
});

const captions = [
  {
    title: 'Live-Edge Oak Slab',
    description: 'A beautifully natural oak slab with an untouched live edge, ready to become your statement river table.',
  },
  {
    title: 'Burr Elm Slab',
    description: 'A richly figured burr elm slab with dramatic grain patterns — ideal for a centrepiece coffee or dining table.',
  },
  {
    title: 'Walnut Book-Match Pair',
    description: 'A matching pair of walnut slabs cut from the same log, perfect for a symmetrical river table with a striking epoxy centre channel.',
  },
];
---

<section class="py-5 sm:py-14">
  <div class="relative mx-auto max-w-5xl px-5">
    <div class="grid grid-cols-1 gap-4 xs:grid-cols-2 md:grid-cols-3">
      {
        stockImages.map((image, index) => (
          <ImageLightbox
            imageSrc={JSON.stringify(image)}
            title={captions[index]?.title}
            description={captions[index]?.description}
            client:load
          >
            <Image
              src={thumbnailImages[index]}
              alt="Product image of epoxy resin table"
              class="select-none"
              loading="lazy"
            />
            <span class="sr-only">Show image</span>
          </ImageLightbox>
        ))
      }
    </div>
  </div>
</section>
